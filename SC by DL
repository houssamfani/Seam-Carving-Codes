# CELL 12 — Seam carving (dynamic programming)
# ════════════════════════════════════════════════════════════
# Content-guided seam carving using the CarvingNet energy map.
# Equations (6)-(8) from Song et al. 2019.

class SeamCarver:
    """
    Content-guided seam carving with CarvingNet deep energy map.

    Usage
    -----
    carver = SeamCarver(model, device)
    resized = carver.resize(image_rgb, target_w, target_h)
    """

    def __init__(self, net: nn.Module, device: torch.device,
                 img_size: int = 256):
        self.net      = net
        self.device   = device
        self.img_size = img_size
        self.net.eval()

    # ── Deep energy map ───────────────────────────────────
    def energy_map(self, img: np.ndarray) -> np.ndarray:
        """
        Run CarvingNet forward pass; return energy map at native resolution.

        Parameters
        ----------
        img : uint8 RGB ndarray, shape (H, W, 3)

        Returns
        -------
        energy : float32 ndarray, shape (H, W), values ∈ [0, 1]
        """
        h_orig, w_orig = img.shape[:2]
        resized = cv2.resize(img, (self.img_size, self.img_size))
        x = (resized.astype(np.float32) / 255.0 - _MEAN) / _STD
        x = torch.from_numpy(x.transpose(2, 0, 1)).unsqueeze(0).to(self.device)

        with torch.no_grad():
            e = self.net(x).squeeze().cpu().numpy()      # 256×256

        return cv2.resize(e, (w_orig, h_orig))           # back to original size

    # ── Cumulative energy (Eq. 8) ─────────────────────────
    @staticmethod
    def _cum_energy_vertical(e: np.ndarray) -> np.ndarray:
        """
        M(i,j) = e(i,j) + min(M(i-1,j-1), M(i-1,j), M(i-1,j+1))
        Vectorised with np.roll for speed.
        """
        M = e.copy()
        h, w = M.shape
        for i in range(1, h):
            prev       = M[i - 1]
            left_shift = np.roll(prev, 1);  left_shift[0]  = prev[0]
            right_shift= np.roll(prev,-1);  right_shift[-1]= prev[-1]
            M[i] += np.minimum(np.minimum(prev, left_shift), right_shift)
        return M

    # ── Find & remove one vertical seam ───────────────────
    @staticmethod
    def _find_seam(M: np.ndarray) -> np.ndarray:
        """Backtrack from minimum in last row — Eq.(6)."""
        h, w  = M.shape
        seam  = np.empty(h, dtype=np.int32)
        seam[-1] = np.argmin(M[-1])
        for i in range(h - 2, -1, -1):
            j = seam[i + 1]
            lo = max(j - 1, 0);  hi = min(j + 2, w)
            seam[i] = lo + np.argmin(M[i, lo:hi])
        return seam

    @staticmethod
    def _remove_seam(arr: np.ndarray, seam: np.ndarray) -> np.ndarray:
        """Remove one vertical seam from a 2-D or 3-D array."""
        h, w = arr.shape[:2]
        mask = np.ones((h, w), dtype=bool)
        mask[np.arange(h), seam] = False
        if arr.ndim == 3:
            return arr[mask].reshape(h, w - 1, arr.shape[2])
        return arr[mask].reshape(h, w - 1)

    # ── Public resize method ───────────────────────────────
    def resize(self, img: np.ndarray,
               target_w: int, target_h: int) -> np.ndarray:
        """
        Reduce image to (target_h, target_w) via content-guided seam carving.

        Vertical seams are removed first, then horizontal
        (image is transposed for horizontal seam removal).
        """
        current = img.copy()

        # ── Vertical seam removal (width reduction) ───────
        n_v = max(0, current.shape[1] - target_w)
        print(f"[Carver] Removing {n_v} vertical seams …")
        for k in range(n_v):
            e    = self.energy_map(current)
            M    = self._cum_energy_vertical(e)
            seam = self._find_seam(M)
            current = self._remove_seam(current, seam)
            if (k + 1) % max(1, n_v // 5) == 0 or k == n_v - 1:
                print(f"  vertical  {k+1:>4d}/{n_v}  →  "
                      f"{current.shape[1]}×{current.shape[0]}")

        # ── Horizontal seam removal (height reduction) ─────
        # Transpose image so horizontal seams become vertical
        n_h = max(0, current.shape[0] - target_h)
        print(f"[Carver] Removing {n_h} horizontal seams …")
        current = current.transpose(1, 0, 2)   # W×H×C
        for k in range(n_h):
            e    = self.energy_map(current)
            M    = self._cum_energy_vertical(e)
            seam = self._find_seam(M)
            current = self._remove_seam(current, seam)
            if (k + 1) % max(1, n_h // 5) == 0 or k == n_h - 1:
                print(f"  horizontal {k+1:>4d}/{n_h}  →  "
                      f"{current.shape[1]}×{current.shape[0]}")
        current = current.transpose(1, 0, 2)   # back to H×W×C

        return current


