# ImageNet normalisation constants
_MEAN = np.array([0.485, 0.456, 0.406], dtype=np.float32)
_STD  = np.array([0.229, 0.224, 0.225], dtype=np.float32)


class BSDS500Dataset(Dataset):
    """
    BSDS500 dataset wrapper for CarvingNet training.

    Input  → RGB image  (3 × 256 × 256)
    Target → Binary edge map  (1 × 256 × 256)  ← used as deep-energy GT
    """

    def __init__(self,
                 data_dir: str,
                 split: str = "train",
                 img_size: int = 256,
                 augment: bool = True):
        self.img_dir  = os.path.join(data_dir, "images",      split)
        self.gt_dir   = os.path.join(data_dir, "ground_truth", split)
        self.img_size = img_size
        self.augment  = augment

        # Keep only images that have a matching GT file
        all_jpegs = sorted(f for f in os.listdir(self.img_dir)
                           if f.endswith(".jpg"))
        self.samples = [
            f for f in all_jpegs
            if os.path.exists(os.path.join(self.gt_dir,
                                           f.replace(".jpg", ".mat")))
        ]
        print(f"[Dataset] {split:5s} → {len(self.samples)} images")

    def __len__(self) -> int:
        return len(self.samples)

    def __getitem__(self, idx: int):
        fname    = self.samples[idx]
        img_path = os.path.join(self.img_dir, fname)
        gt_path  = os.path.join(self.gt_dir,  fname.replace(".jpg", ".mat"))

        # ── Load & resize image ───────────────────────────
        img = cv2.cvtColor(cv2.imread(img_path), cv2.COLOR_BGR2RGB)
        img = cv2.resize(img, (self.img_size, self.img_size))

        # ── Load & resize ground-truth edge map ───────────
        gt = load_gt_edge_map(gt_path, (self.img_size, self.img_size))

        # ── Data augmentation (paper: rotation + flipping) ──
        if self.augment:
            if np.random.rand() > 0.5:           # horizontal flip
                img = cv2.flip(img, 1)
                gt  = cv2.flip(gt,  1)
            if np.random.rand() > 0.5:           # vertical flip
                img = cv2.flip(img, 0)
                gt  = cv2.flip(gt,  0)
            k = np.random.randint(0, 4)          # 90° rotation ×k
            img = np.rot90(img, k).copy()
            gt  = np.rot90(gt,  k).copy()

        # ── Normalise ─────────────────────────────────────
        img = img.astype(np.float32) / 255.0
        img = (img - _MEAN) / _STD

        img_t = torch.from_numpy(img.transpose(2, 0, 1))   # CHW
        gt_t  = torch.from_numpy(gt[np.newaxis])            # 1HW
        return img_t, gt_t


# ════════════════════════════════════════════════════════════
# CELL 6 — CarvingNet Architecture
# ════════════════════════════════════════════════════════════
# Encoder-Decoder CNN (U-Net style) as described in Figure 3 /
# Table 1 of Song et al. 2019.
#
# Table 1 summary:
#   Input     : 256×256×3
#   Enc L1    : Conv3×3/32  ×2                      → 256×256×32  + MaxPool
#   Enc L2    : Conv3×3/64  ×2                      → 128×128×64  + MaxPool
#   Enc L3    : Conv3×3/128 ×2                      → 64×64×128   + MaxPool
#   Enc L4    : Conv3×3/256 ×2                      → 32×32×256   + MaxPool
#   Bridge L5 : Conv3×3/512 ×2                      → 16×16×512
#   Dec L6    : UpConv + Concat(skip4) + Conv×2/256 → 32×32×256
#   Dec L7    : UpConv + Concat(skip3) + Conv×2/128 → 64×64×128
#   Dec L8    : UpConv + Concat(skip2) + Conv×2/64  → 128×128×64
#   Dec L9    : UpConv + Concat(skip1) + Conv×2/32  → 256×256×32
#   Output L10: Conv1×1/1  + Sigmoid                → 256×256×1

class _EncBlock(nn.Module):
    """Conv3×3→ReLU→Conv3×3→ReLU  (features saved for skip) + MaxPool."""

    def __init__(self, in_ch: int, out_ch: int):
        super().__init__()
        self.conv = nn.Sequential(
            nn.Conv2d(in_ch,  out_ch, 3, padding=1, bias=True), nn.ReLU(True),
            nn.Conv2d(out_ch, out_ch, 3, padding=1, bias=True), nn.ReLU(True),
        )
        self.pool = nn.MaxPool2d(2, 2)

    def forward(self, x):
        feat   = self.conv(x)   # → skip connection
        pooled = self.pool(feat)
        return feat, pooled


class _Bridge(nn.Module):
    """Bottleneck block (Level 5): no pooling."""

    def __init__(self, in_ch: int, out_ch: int):
        super().__init__()
        self.conv = nn.Sequential(
            nn.Conv2d(in_ch,  out_ch, 3, padding=1, bias=True), nn.ReLU(True),
            nn.Conv2d(out_ch, out_ch, 3, padding=1, bias=True), nn.ReLU(True),
        )

    def forward(self, x):
        return self.conv(x)


class _DecBlock(nn.Module):
    """UpConv2×2 → concat(skip) → Conv3×3→ReLU→Conv3×3→ReLU."""

    def __init__(self, in_ch: int, skip_ch: int, out_ch: int):
        super().__init__()
        self.up   = nn.ConvTranspose2d(in_ch, out_ch, kernel_size=2, stride=2)
        self.conv = nn.Sequential(
            nn.Conv2d(out_ch + skip_ch, out_ch, 3, padding=1, bias=True), nn.ReLU(True),
            nn.Conv2d(out_ch,           out_ch, 3, padding=1, bias=True), nn.ReLU(True),
        )

    def forward(self, x, skip):
        x = self.up(x)
        # Pad if spatial sizes differ (handles odd-dimension inputs)
        dy = skip.size(2) - x.size(2)
        dx = skip.size(3) - x.size(3)
        if dy or dx:
            x = nn.functional.pad(x, [dx // 2, dx - dx // 2,
                                       dy // 2, dy - dy // 2])
        return self.conv(torch.cat([skip, x], dim=1))


class CarvingNet(nn.Module):
    """
    CarvingNet — Encoder-Decoder CNN for deep energy map generation.

    Input  : (B, 3, 256, 256)  — RGB image
    Output : (B, 1, 256, 256)  — Energy map, values ∈ [0, 1]

    Reference: Song et al., IEEE Access 2019, Table 1 / Figure 3.
    """

    def __init__(self):
        super().__init__()
        # Encoder (Levels 1-4)
        self.enc1 = _EncBlock(3,   32)    # 256→128 (after pool)
        self.enc2 = _EncBlock(32,  64)    # 128→64
        self.enc3 = _EncBlock(64,  128)   # 64→32
        self.enc4 = _EncBlock(128, 256)   # 32→16

        # Bridge (Level 5)
        self.bridge = _Bridge(256, 512)   # stays 16×16

        # Decoder (Levels 6-9)
        self.dec4 = _DecBlock(512, 256, 256)   # 16→32
        self.dec3 = _DecBlock(256, 128, 128)   # 32→64
        self.dec2 = _DecBlock(128, 64,  64)    # 64→128
        self.dec1 = _DecBlock(64,  32,  32)    # 128→256

        # Output (Level 10 — 1×1 conv + Sigmoid)
        self.out = nn.Sequential(
            nn.Conv2d(32, 1, kernel_size=1),
            nn.Sigmoid(),
        )

        self._init_weights()

    def _init_weights(self):
        for m in self.modules():
            if isinstance(m, (nn.Conv2d, nn.ConvTranspose2d)):
                nn.init.kaiming_normal_(m.weight,
                                        mode="fan_out",
                                        nonlinearity="relu")
                if m.bias is not None:
                    nn.init.zeros_(m.bias)

    def forward(self, x):
        # Encoder
        s1, x = self.enc1(x)   # s1: 256×256×32
        s2, x = self.enc2(x)   # s2: 128×128×64
        s3, x = self.enc3(x)   # s3: 64×64×128
        s4, x = self.enc4(x)   # s4: 32×32×256

        # Bridge
        x = self.bridge(x)     #     16×16×512

        # Decoder (with skip connections → "copy and crop")
        x = self.dec4(x, s4)   # 32×32×256
        x = self.dec3(x, s3)   # 64×64×128
        x = self.dec2(x, s2)   # 128×128×64
        x = self.dec1(x, s1)   # 256×256×32

        return self.out(x)     # 256×256×1

    @property
    def n_params(self) -> int:
        return sum(p.numel() for p in self.parameters() if p.requires_grad)


# ════════════════════════════════════════════════════════════
# CELL 7 — Loss functions
# ════════════════════════════════════════════════════════════

class DiceLoss(nn.Module):
    """
    Dice Similarity Loss.

    DiceSimilarity(EM, P) = 2|EM ∩ P| / (|EM| + |P|)   Eq.(9) in the paper.
    Loss = 1 − DiceSimilarity  (minimised during training).
    """

    def __init__(self, smooth: float = 1e-6):
        super().__init__()
        self.smooth = smooth

    def forward(self, pred: torch.Tensor, target: torch.Tensor) -> torch.Tensor:
        p = pred.contiguous().view(-1)
        t = target.contiguous().view(-1)
        intersection = (p * t).sum()
        dice = (2.0 * intersection + self.smooth) / (
            p.sum() + t.sum() + self.smooth
        )
        return 1.0 - dice


class CombinedLoss(nn.Module):
    """
    Dice  +  weighted Binary-Cross-Entropy.

    BCE pos_weight down-weights the majority (non-edge) class to handle
    the severe class imbalance in edge-detection tasks.
    """

    def __init__(self, dice_w: float = 0.5, bce_w: float = 0.5,
                 pos_weight: float = 5.0):
        super().__init__()
        self.dice   = DiceLoss()
        self.bce    = nn.BCEWithLogitsLoss(
            pos_weight=torch.tensor(pos_weight))
        self.dice_w = dice_w
        self.bce_w  = bce_w

    def forward(self, pred: torch.Tensor,
                target: torch.Tensor) -> torch.Tensor:
        # pred is already passed through Sigmoid inside CarvingNet,
        # so we use standard BCELoss here (not BCEWithLogitsLoss).
        # Use DiceLoss as primary (as stated in paper).
        return self.dice_w * self.dice(pred, target) + \
               self.bce_w  * nn.functional.binary_cross_entropy(pred, target)


# ════════════════════════════════════════════════════════════
# CELL 8 — Training helpers
# ════════════════════════════════════════════════════════════

def dice_score(pred: torch.Tensor, target: torch.Tensor,
               threshold: float = 0.5, smooth: float = 1e-6) -> float:
    """Binary Dice coefficient for monitoring (not the loss)."""
    with torch.no_grad():
        p = (pred > threshold).float().contiguous().view(-1)
        t = target.contiguous().view(-1)
        inter = (p * t).sum()
        return ((2.0 * inter + smooth) /
                (p.sum() + t.sum() + smooth)).item()


def run_epoch(model, loader, criterion, optimizer=None, device="cpu"):
    """One training or validation epoch. Pass optimizer=None for val."""
    training = optimizer is not None
    model.train(training)
    total_loss = total_dice = 0.0

    ctx = torch.enable_grad() if training else torch.no_grad()
    with ctx:
        for imgs, gts in loader:
            imgs, gts = imgs.to(device), gts.to(device)
            preds = model(imgs)
            loss  = criterion(preds, gts)

            if training:
                optimizer.zero_grad()
                loss.backward()
                optimizer.step()

            total_loss += loss.item()
            total_dice += dice_score(preds, gts)

    n = len(loader)
    return total_loss / n, total_dice / n


