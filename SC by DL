# CELL 4 — Ground-truth edge-map loader (BSDS500 .mat files)
# ════════════════════════════════════════════════════════════
def load_gt_edge_map(gt_path: str,
                     img_size: tuple = (256, 256),
                     threshold: float = 0.33) -> np.ndarray:
    """
    Load BSDS500 .mat ground-truth and return a binary edge map.

    Annotators are averaged; a pixel is considered an edge if
    ≥ `threshold` fraction of annotators marked it.

    Returns
    -------
    edge_map : float32 ndarray, shape (H, W), values ∈ {0, 1}
    """
    def _avg_and_thresh(maps, thr):
        avg = np.mean(maps, axis=0).astype(np.float32)
        return (avg >= thr).astype(np.float32)

    # ── Try scipy (v5 / v6 .mat) ──────────────────────────
    try:
        mat = sio.loadmat(gt_path, squeeze_me=False)
        gt_cell = mat["ground_truth"][0]           # shape: (n_ann,)
        maps = []
        for ann in gt_cell:
            bnd = ann["Boundaries"][0, 0]
            if hasattr(bnd, "toarray"):           # sparse matrix
                bnd = bnd.toarray()
            maps.append((bnd > 0).astype(np.float32))
        edge = _avg_and_thresh(maps, threshold)
        return cv2.resize(edge, img_size, interpolation=cv2.INTER_NEAREST)

    except Exception:
        pass

    # ── Fall back to h5py (v7.3 .mat) ────────────────────
    try:
        with h5py.File(gt_path, "r") as f:
            gt_refs = f["ground_truth"]            # shape: (1, n_ann)
            maps = []
            for i in range(gt_refs.shape[1]):
                ref = gt_refs[0, i]
                bnd = f[ref]["Boundaries"][0, 0]
                bnd = f[bnd][:]
                maps.append((bnd > 0).astype(np.float32))
            edge = _avg_and_thresh(maps, threshold)
        return cv2.resize(edge, img_size, interpolation=cv2.INTER_NEAREST)

    except Exception:
        pass

    # ── Fallback: zero map (should not occur on valid BSDS500) ──
    return np.zeros(img_size[::-1], dtype=np.float32)


