    def find_vertical_seam(self, energy):
        """
        Trouve le seam vertical d'énergie minimale
        Retourne: seam (liste des colonnes à supprimer)
        """
        rows, cols = energy.shape

        # Matrice d'énergie cumulée
        M = energy.copy()

        # Table de backtracking - stocke le chemin
        backtrack = np.zeros_like(M, dtype=int)

        # Programmation dynamique
        for i in range(1, rows):
            for j in range(cols):
                if j == 0:
                    # Bord gauche: seulement 2 voisins
                    min_idx = np.argmin(M[i-1, j:j+2])
                    M[i, j] += M[i-1, j + min_idx]
                    backtrack[i, j] = j + min_idx
                elif j == cols - 1:
                    # Bord droit: seulement 2 voisins
                    min_idx = np.argmin(M[i-1, j-1:j+1])
                    M[i, j] += M[i-1, j - 1 + min_idx]
                    backtrack[i, j] = j - 1 + min_idx
                else:
                    # Milieu: 3 voisins
                    min_idx = np.argmin(M[i-1, j-1:j+2])
                    M[i, j] += M[i-1, j - 1 + min_idx]
                    backtrack[i, j] = j - 1 + min_idx

        # Reconstruire le seam
        seam = []
        j = np.argmin(M[-1])  # Dernière ligne, colonne avec min énergie

        for i in range(rows-1, -1, -1):
            seam.append(j)
            if i > 0:
                j = backtrack[i, j]

        return list(reversed(seam))

    def find_horizontal_seam(self, energy):
        """
        Trouve le seam horizontal d'énergie minimale
        En pratique, on transpose l'énergie et on utilise find_vertical_seam
        """
        # Transposer pour utiliser l'algorithme vertical
        energy_T = energy.T
        seam_T = self.find_vertical_seam(energy_T)
        # Le seam horizontal est la transposée
        return seam_T

    def remove_vertical_seam(self, img, seam):
        """
        Supprime un seam vertical de l'image
        """
        h, w = img.shape[:2]

        if len(img.shape) == 3:
            # Image couleur
            output = np.zeros((h, w-1, 3), dtype=img.dtype)
            for i in range(h):
                col = seam[i]
                output[i, :col] = img[i, :col]
                output[i, col:] = img[i, col+1:]
        else:
            # Image grise
            output = np.zeros((h, w-1), dtype=img.dtype)
            for i in range(h):
                col = seam[i]
                output[i, :col] = img[i, :col]
                output[i, col:] = img[i, col+1:]

        return output

    def remove_horizontal_seam(self, img, seam):
        """
        Supprime un seam horizontal de l'image
        """
        if len(img.shape) == 3:
            # Image couleur: transposer, supprimer vertical, retransposer
            img_T = np.transpose(img, (1, 0, 2))
            output_T = self.remove_vertical_seam(img_T, seam)
            output = np.transpose(output_T, (1, 0, 2))
        else:
            # Image grise
            img_T = img.T
            output_T = self.remove_vertical_seam(img_T, seam)
            output = output_T.T

        return output

    def visualize_seam(self, img, seam, direction='vertical'):
        """
        Visualise le seam sur l'image en rouge
        """
        vis_img = img.copy()
        h, w = vis_img.shape[:2]

        if direction == 'vertical':
            for i, j in enumerate(seam):
                if 0 <= i < h and 0 <= j < w:
                    if len(vis_img.shape) == 3:
                        vis_img[i, j] = [0, 0, 255]  # Rouge en BGR
                    else:
                        vis_img[i, j] = 255
        else:  # horizontal
            for j, i in enumerate(seam):
                if 0 <= i < h and 0 <= j < w:
                    if len(vis_img.shape) == 3:
                        vis_img[i, j] = [0, 0, 255]
                    else:
                        vis_img[i, j] = 255

        return vis_img

    def resize_vertical(self, num_seams, visualize_every=10):
        """
        Redimensionne l'image en supprimant des seams verticaux
        """
        img = self.image.copy()
        seams_removed = 0
        history = []

        print(f"🔄 Suppression de {num_seams} seams verticaux...")
        start_time = time.time()

        for i in range(num_seams):
            # Calculer la carte d'énergie
            energy = self.compute_energy_map(img)

            # Trouver le seam optimal
            seam = self.find_vertical_seam(energy)

            # Visualisation périodique
            if visualize_every > 0 and (i % visualize_every == 0 or i == num_seams-1):
                vis_img = self.visualize_seam(img, seam, 'vertical')
                history.append({
                    'step': i+1,
                    'image': vis_img,
                    'seam': seam,
                    'dimensions': img.shape
                })

            # Supprimer le seam
            img = self.remove_vertical_seam(img, seam)
            seams_removed += 1

            # Progression
            if (i+1) % 10 == 0 or i+1 == num_seams:
                print(f"   Progression: {i+1}/{num_seams} seams supprimés")

        elapsed = time.time() - start_time
        print(f"✅ Terminé en {elapsed:.2f} secondes")
        print(f"   Dimensions finales: {img.shape[1]} x {img.shape[0]}")

        return img, history

    def resize_horizontal(self, num_seams, visualize_every=10):
        """
        Redimensionne l'image en supprimant des seams horizontaux
        """
        img = self.image.copy()
        seams_removed = 0
        history = []

        print(f"🔄 Suppression de {num_seams} seams horizontaux...")
        start_time = time.time()

        for i in range(num_seams):
            # Calculer la carte d'énergie
            energy = self.compute_energy_map(img)

            # Trouver le seam optimal
            seam = self.find_horizontal_seam(energy)

            # Visualisation périodique
            if visualize_every > 0 and (i % visualize_every == 0 or i == num_seams-1):
                vis_img = self.visualize_seam(img, seam, 'horizontal')
                history.append({
                    'step': i+1,
                    'image': vis_img,
                    'seam': seam,
                    'dimensions': img.shape
                })

            # Supprimer le seam
            img = self.remove_horizontal_seam(img, seam)
            seams_removed += 1

            # Progression
            if (i+1) % 10 == 0 or i+1 == num_seams:
                print(f"   Progression: {i+1}/{num_seams} seams supprimés")

        elapsed = time.time() - start_time
        print(f"✅ Terminé en {elapsed:.2f} secondes")
        print(f"   Dimensions finales: {img.shape[1]} x {img.shape[0]}")

        return img, history

    def resize_to_dimensions(self, new_width, new_height, visualize=True):
        """
        Redimensionne l'image à des dimensions spécifiques
        """
        img = self.image.copy()
        current_h, current_w = img.shape[:2]

        print(f"📐 Redimensionnement de {current_w}x{current_h} → {new_width}x{new_height}")

        # Supprimer les seams horizontaux
        seams_h = current_h - new_height
        if seams_h > 0:
            print(f"\n📏 Suppression de {seams_h} seams horizontaux")
            img, _ = self.resize_horizontal(seams_h, visualize_every=0)
            self.image = img  # Mettre à jour l'image courante

        # Supprimer les seams verticaux
        seams_w = current_w - new_width
        if seams_w > 0:
            print(f"\n📏 Suppression de {seams_w} seams verticaux")
            img, _ = self.resize_vertical(seams_w, visualize_every=0)

        if visualize:
            self.display_result(self.original, img)

        return img

    def display_energy_map(self):
        """
        Affiche la carte d'énergie de l'image
        """
        energy = self.compute_energy_map(self.image)

        fig, axes = plt.subplots(1, 2, figsize=(12, 5))

        # Image originale
        axes[0].imshow(cv2.cvtColor(self.image, cv2.COLOR_BGR2RGB))
        axes[0].set_title("Image Originale")
        axes[0].axis('off')

        # Carte d'énergie
        energy_norm = (energy * 255 / energy.max()).astype(np.uint8)
        axes[1].imshow(energy_norm, cmap='hot')
        axes[1].set_title("Carte d'Énergie (zones claires = importantes)")
        axes[1].axis('off')

        plt.tight_layout()
        plt.show()

        return energy

    def display_seam_removal_process(self, history, num_cols=4):
        """
        Affiche la progression de la suppression des seams
        """
        if not history:
            print("Aucun historique à afficher")
            return

        n_images = len(history)
        n_rows = (n_images + num_cols - 1) // num_cols

        fig, axes = plt.subplots(n_rows, num_cols, figsize=(15, 4 * n_rows))
        axes = axes.flatten() if n_rows > 1 else [axes] if n_images > 1 else [axes]

        for idx, step_data in enumerate(history):
            img_rgb = cv2.cvtColor(step_data['image'], cv2.COLOR_BGR2RGB)
            axes[idx].imshow(img_rgb)
            axes[idx].set_title(f"Étape {step_data['step']}\n{step_data['dimensions'][1]}x{step_data['dimensions'][0]}")
            axes[idx].axis('off')

        # Cacher les axes inutilisés
        for idx in range(len(history), len(axes)):
            axes[idx].axis('off')

        plt.tight_layout()
        plt.show()

    def display_result(self, original, result):
        """
        Affiche l'image originale et le résultat
        """
        fig, axes = plt.subplots(1, 2, figsize=(14, 6))

        # Original
        axes[0].imshow(cv2.cvtColor(original, cv2.COLOR_BGR2RGB))
        axes[0].set_title(f"Originale\n{original.shape[1]} x {original.shape[0]}")
        axes[0].axis('off')

        # Résultat
        axes[1].imshow(cv2.cvtColor(result, cv2.COLOR_BGR2RGB))
        axes[1].set_title(f"Après Seam Carving\n{result.shape[1]} x {result.shape[0]}")
        axes[1].axis('off')

        plt.suptitle("Comparaison Original vs Seam Carving", fontsize=14)
        plt.tight_layout()
        plt.show()

    def save_result(self, result, filename="seam_carved_result.jpg"):
        """
        Sauvegarde le résultat dans Colab et le rend téléchargeable
        """
        cv2.imwrite(filename, result)
        print(f"✅ Image sauvegardée: {filename}")

        # Proposer le téléchargement
        files.download(filename)


