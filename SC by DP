def demo_quick_start():
    """
    Démonstration rapide - à exécuter en premier
    """
    print("="*60)
    print("🎯 SEAM CARVING ALGORITHM - DEMO")
    print("="*60)

    # Créer l'instance
    sc = SeamCarving()

    # Upload d'une image
    sc.upload_image()

    # Afficher la carte d'énergie
    print("\n📊 Carte d'énergie:")
    sc.display_energy_map()

    # Choisir l'opération
    print("\n" + "="*60)
    print("Que voulez-vous faire?")
    print("1. Supprimer des seams verticaux")
    print("2. Supprimer des seams horizontaux")
    print("3. Redimensionner à des dimensions spécifiques")
    print("4. Tout essayer")

    choix = input("\nVotre choix (1-4): ")

    if choix == '1':
        num = int(input("Nombre de seams à supprimer (vertical): "))
        result, history = sc.resize_vertical(num, visualize_every=max(1, num//5))
        sc.display_seam_removal_process(history)
        sc.display_result(sc.original, result)
        sc.save_result(result)

    elif choix == '2':
        num = int(input("Nombre de seams à supprimer (horizontal): "))
        result, history = sc.resize_horizontal(num, visualize_every=max(1, num//5))
        sc.display_seam_removal_process(history)
        sc.display_result(sc.original, result)
        sc.save_result(result)

    elif choix == '3':
        new_w = int(input("Nouvelle largeur: "))
        new_h = int(input("Nouvelle hauteur: "))
        result = sc.resize_to_dimensions(new_w, new_h)
        sc.save_result(result)

    else:
        # Demo complète
        print("\n📹 Démonstration complète...")

        # Supprimer 30 seams verticaux
        result_v, hist_v = sc.resize_vertical(30)
        sc.display_seam_removal_process(hist_v)

        # Restaurer l'image originale
        sc.image = sc.original.copy()

        # Supprimer 20 seams horizontaux
        result_h, hist_h = sc.resize_horizontal(20)
        sc.display_seam_removal_process(hist_h)

        sc.save_result(result_h)


