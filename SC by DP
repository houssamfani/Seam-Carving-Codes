def batch_process_example():
    """
    Exemple de traitement par lots
    """
    print("🚀 Traitement par lots d'images...")

    # Créer plusieurs images de test
    images = []
    sc = SeamCarving()

    for i in range(3):
        img = np.random.randint(0, 255, (200, 300, 3), dtype=np.uint8)
        cv2.putText(img, f"Image {i+1}", (50, 100),
                   cv2.FONT_HERSHEY_SIMPLEX, 1, (255, 255, 255), 2)
        cv2.imwrite(f"test_{i}.jpg", img)
        images.append(f"test_{i}.jpg")

    # Traiter chaque image
    for path in images:
        print(f"\n📷 Traitement de {path}")
        sc.load_image_from_path(path)
        result = sc.resize_vertical(50, visualize_every=0)
        sc.save_result(result, f"result_{path}")


