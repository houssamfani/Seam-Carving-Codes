    Implémentation complète de l'algorithme Seam Carving
    avec programmation dynamique pour Google Colab
    """

    def __init__(self):
        self.image = None
        self.original = None
        self.energy_maps = []
        self.seam_history = []

    def upload_image(self):
        """Upload une image depuis l'ordinateur vers Colab"""
        print("📤 Veuillez sélectionner une image...")
        uploaded = files.upload()

        for filename in uploaded.keys():
            # Lire l'image
            file_bytes = np.frombuffer(uploaded[filename], np.uint8)
            self.image = cv2.imdecode(file_bytes, cv2.IMREAD_COLOR)
            self.original = self.image.copy()
            print(f"✅ Image chargée: {filename}")
            print(f"   Dimensions: {self.image.shape[1]} x {self.image.shape[0]}")
            return filename

        raise ValueError("Aucune image téléchargée")

    def load_image_from_path(self, path):
        """Charge une image depuis un chemin (pour les datasets Colab)"""
        self.image = cv2.imread(path)
        if self.image is None:
            raise ValueError(f"Impossible de charger l'image: {path}")
        self.original = self.image.copy()
        print(f"✅ Image chargée: {path}")
        print(f"   Dimensions: {self.image.shape[1]} x {self.image.shape[0]}")

    def compute_energy_map(self, img):
        """
        Calcule la carte d'énergie en utilisant le gradient de Sobel
        """
        if len(img.shape) == 3:
            gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)
        else:
            gray = img

        # Filtre de Sobel pour détecter les contours
        energy = filters.sobel(gray.astype("float"))

        return energy

